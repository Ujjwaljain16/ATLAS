# ─────────────────────────────────────────
#  ATLAS — Environment Configuration
#  Copy this file to .env and edit values
# ─────────────────────────────────────────

# Show the browser window during execution (useful for debugging)
# Default: true (headless)
ATLAS_HEADLESS=false

# Allow the agent to navigate to any domain.
# Set to false to permit cross-domain redirects (e.g. SSO flows)
# Default: true (strict)
ATLAS_STRICT_DOMAIN_CHECK=true

# Dispatch observability events asynchronously.
# Enable for high-throughput benchmarking where event latency is acceptable.
# Default: false (synchronous)
ATLAS_ASYNC_EVENTS=false
