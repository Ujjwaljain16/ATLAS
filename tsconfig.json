{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@core/*": ["./src/core/*"],
      "@config/*": ["./src/config/*"],
      "@perception/*": ["./src/perception/*"],
      "@reasoning/*": ["./src/reasoning/*"],
      "@tools/*": ["./src/tools/*"],
      "@memory/*": ["./src/memory/*"],
      "@resilience/*": ["./src/resilience/*"],
      "@observability/*": ["./src/observability/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src/**/*"]
}
